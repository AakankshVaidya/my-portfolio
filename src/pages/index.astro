---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { personalInfo, experience, leadership, education, courses, skills, interests } from "../content/resume.ts";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

const gradients = [
  "linear-gradient(135deg, #1a1a2e, #16213e, #0f3460)",
  "linear-gradient(135deg, #1a1410, #2a1e14, #3a2818)",
  "linear-gradient(135deg, #0a1a1a, #0e2626, #123232)",
];

const vizCards = [
  { id: "network", canvasId: "networkCanvas", label: "Network graph", hint: "click & drag" },
  { id: "prediction", canvasId: "predictionCanvas", label: "Predictive model", hint: "hover" },
  { id: "distribution", canvasId: "distCanvas", label: "Distribution", hint: "hover" },
  { id: "breakdown", canvasId: "donutCanvas", label: "Breakdown", hint: "hover" },
];
---

<Base>
  <section class="hero">
    <div class="hero-text">
      <div class="hero-label">Portfolio &mdash; {new Date().getFullYear()}</div>
      <h1>
        {personalInfo.tagline.split(" ").slice(0, -1).join(" ")}
        <br /><em>{personalInfo.tagline.split(" ").slice(-1)}</em>
      </h1>
      <p class="hero-description">Studying Data Science and QSS at Dartmouth College. I build mathematical models and data visualizations packaged in a design that is both aesthetic and interactive.</p>
      <div class="hero-playground-hint">
        <span class="hint-text">Who said data had to be boring? Go play with it</span>
        <svg class="hint-arrow" viewBox="0 0 80 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 12 H64 M54 4 L68 12 L54 20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">View Projects &darr;</a>
        <a href="#resume" class="btn btn-ghost">Resume</a>
      </div>
    </div>
    <div class="hero-cards" id="heroCardStack">
      {vizCards.map((card, i) => (
        <div class="hero-card-slot" data-slot={i}>
          <div class="hero-viz-card" data-card={card.id}>
            <div class="hero-viz-label">{card.label}</div>
            <div class="hero-action-hint">{card.hint}</div>
            <div class="hero-viz-area">
              <canvas id={card.canvasId}></canvas>
            </div>
            <div class="hero-drag-handle">
              <div class="hero-drag-row"><div class="hero-drag-dot"></div><div class="hero-drag-dot"></div></div>
              <div class="hero-drag-row"><div class="hero-drag-dot"></div><div class="hero-drag-dot"></div></div>
              <div class="hero-drag-row"><div class="hero-drag-dot"></div><div class="hero-drag-dot"></div></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="projects">
    <div class="section-header">
      <div class="section-label">Selected Work</div>
      <h2 class="section-title">Projects</h2>
    </div>
    <div class="projects-grid">
      {projects.map((project, i) => (
        <a href={project.data.link || project.data.github || "#"} class="project-card" target="_blank" rel="noopener">
          <div class="project-image-wrapper">
            {project.data.image ? (
              <img src={project.data.image} alt={project.data.title} class="project-image" />
            ) : (
              <div class="project-placeholder" style={`background: ${gradients[i % gradients.length]}`}>
                {String(i + 1).padStart(2, "0")}
              </div>
            )}
          </div>
          <div class="project-content">
            <div class="project-tags">
              {project.data.tags.map((tag: string) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>
            <span class="project-link">View project &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section id="resume" class="resume-section">
    <div class="section-header">
      <div class="section-label">Experience</div>
      <h2 class="section-title">Resume</h2>
    </div>
    <div class="resume-layout">
      <div class="resume-left">
        <div class="timeline">
          {experience.map((item) => (
            <div class="timeline-item">
              <div class="timeline-dot" />
              <div class="timeline-date">{item.date}</div>
              <div class="timeline-role">{item.role}</div>
              <div class="timeline-company">{item.company}</div>
              <div class="timeline-desc">{item.description}</div>
              <div class="timeline-skills">
                {item.skills.map((s: string) => (
                  <span class="timeline-skill">{s}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
        <div class="sub-section">
          <div class="section-label">Leadership</div>
          <div class="timeline">
            {leadership.map((item) => (
              <div class="timeline-item">
                <div class="timeline-dot" />
                <div class="timeline-date">{item.date}</div>
                <div class="timeline-role">{item.role}</div>
                <div class="timeline-company">{item.company}</div>
                <div class="timeline-desc">{item.description}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="resume-right">
        <div class="sidebar-card"><div class="sidebar-label">Skills</div><div class="pill-grid">{skills.map((s) => (<span class="pill">{s}</span>))}</div></div>
        <div class="sidebar-card"><div class="sidebar-label">Courses</div><div class="pill-grid">{courses.map((c) => (<span class="pill">{c}</span>))}</div></div>
        <div class="sidebar-card"><div class="sidebar-label">Interests</div><div class="pill-grid">{interests.map((i) => (<span class="pill">{i}</span>))}</div></div>
      </div>
    </div>
    {education.length > 0 && (
      <div class="edu-section">
        <div class="section-label">Education</div>
        <div class="education-grid">
          {education.map((ed) => (
            <div class="edu-card">
              <div class="edu-degree">{ed.degree}</div>
              <div class="edu-school">{ed.school}</div>
              <div class="edu-year">{ed.years}</div>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</Base>

<script is:inline src="/hero-viz.js" defer></script>

<style>
  .hero {
    min-height: 100vh; display: flex; align-items: center;
    justify-content: space-between; padding: 120px 48px 80px; gap: 48px;
  }
  .hero-text { flex: 1; max-width: 520px; }
  .hero-label {
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 24px; font-weight: 500;
    opacity: 0; animation: fadeUp 0.8s ease forwards 0.2s;
  }
  .hero h1 {
    font-family: var(--font-display); font-size: clamp(42px, 6vw, 72px);
    font-weight: 700; line-height: 1.08; letter-spacing: -0.03em;
    margin-bottom: 28px; opacity: 0; animation: fadeUp 0.8s ease forwards 0.4s;
  }
  .hero h1 em {
    font-family: var(--font-serif); font-style: italic;
    font-weight: 400; color: var(--accent);
  }
  .hero-description {
    font-size: 18px; color: var(--text-secondary); max-width: 540px;
    line-height: 1.8; opacity: 0; animation: fadeUp 0.8s ease forwards 0.6s;
  }
  .hero-playground-hint {
    margin-top: 36px; display: flex; align-items: center; gap: 14px;
    opacity: 0; animation: fadeUp 0.8s ease forwards 0.8s;
  }
  .hint-text {
    font-family: var(--font-serif); font-style: italic;
    font-size: 17px; color: var(--accent); opacity: 0.6;
  }
  .hint-arrow {
    width: 56px; height: 20px; color: var(--accent); opacity: 0.45;
    animation: nudgeRight 2s ease-in-out infinite 2.5s;
  }
  @keyframes nudgeRight {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(8px); }
  }
  .hero-cta {
    margin-top: 24px; display: flex; gap: 16px;
    opacity: 0; animation: fadeUp 0.8s ease forwards 1s;
  }

  .hero-cards {
    width: 500px; flex-shrink: 0;
    opacity: 0; animation: fadeUp 1s ease forwards 0.5s;
  }
  .hero-card-slot {
    width: 100%; height: 160px; margin-bottom: 12px;
    position: relative; transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .hero-card-slot:last-child { margin-bottom: 0; }
  .hero-viz-card {
    position: absolute; left: 0; top: 0; width: 100%; height: 100%;
    background: var(--card-bg); border: 1px solid rgba(200,168,124,0.12);
    border-radius: 14px; cursor: grab; user-select: none;
    display: flex; align-items: stretch; overflow: visible;
    transition: border-color 0.3s, box-shadow 0.3s; z-index: 1;
  }
  .hero-viz-card:hover { border-color: rgba(200,168,124,0.25); box-shadow: 0 4px 20px rgba(0,0,0,0.2); }
  .hero-viz-card.dragging {
    cursor: grabbing; box-shadow: 0 24px 64px rgba(0,0,0,0.6), 0 0 0 1px rgba(200,168,124,0.4);
    border-color: rgba(200,168,124,0.4); z-index: 1000; transform: scale(1.04) rotate(1.5deg);
  }
  .hero-viz-card.snapping {
    transition: left 1.6s cubic-bezier(0.34,1.56,0.64,1), top 1.6s cubic-bezier(0.34,1.56,0.64,1),
                transform 1.6s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.8s ease, border-color 0.8s ease;
    transform: scale(1) rotate(0deg); box-shadow: none; border-color: rgba(200,168,124,0.12);
  }
  .hero-viz-label {
    position: absolute; top: 10px; left: 14px;
    font-size: 8px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--accent); font-weight: 600; pointer-events: none; z-index: 2;
    background: rgba(22,22,26,0.75); padding: 3px 8px; border-radius: 4px; backdrop-filter: blur(4px);
  }

  /* Action hints — show on initial load AND on hover */
  .hero-action-hint {
    position: absolute; bottom: 10px; right: 14px;
    font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--accent); font-weight: 400; pointer-events: none; z-index: 2;
    opacity: 0;
    animation: hintInitial 5s ease forwards 1.5s;
    transition: opacity 0.3s ease;
  }
  /* Initial load animation */
  @keyframes hintInitial {
    0% { opacity: 0; }
    15% { opacity: 0.35; }
    70% { opacity: 0.35; }
    100% { opacity: 0; }
  }
  /* Show again on card hover */
  .hero-viz-card:hover .hero-action-hint {
    opacity: 0.35;
    animation: none;
  }

  .hero-viz-area {
    flex: 1; min-width: 0; position: relative; padding: 12px 14px;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-viz-area canvas { width: 100%; height: 100%; display: block; }
  .hero-drag-handle {
    display: flex; flex-direction: column; gap: 3px; justify-content: center;
    align-items: center; width: 28px; flex-shrink: 0; opacity: 0; transition: opacity 0.3s; pointer-events: none;
  }
  .hero-viz-card:hover .hero-drag-handle { opacity: 0.35; }
  .hero-viz-card.dragging .hero-drag-handle { opacity: 0.5; }
  .hero-drag-row { display: flex; gap: 3px; }
  .hero-drag-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--accent); }

  section { padding: 100px 48px; }
  .section-header { margin-bottom: 60px; }
  .resume-section { background: var(--bg-secondary); }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
  .project-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all 0.4s cubic-bezier(0.25,0.46,0.45,0.94); display: block; }
  .project-card:hover { border-color: var(--border-hover); background: var(--bg-card-hover); transform: translateY(-4px); }
  .project-image-wrapper { height: 200px; overflow: hidden; }
  .project-image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .project-card:hover .project-image { transform: scale(1.03); }
  .project-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; font-weight: 200; color: var(--text-muted); }
  .project-content { padding: 24px; }
  .project-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
  .project-tag { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent); background: var(--accent-dim); padding: 4px 10px; border-radius: 4px; }
  .project-title { font-family: var(--font-display); font-size: 20px; font-weight: 600; letter-spacing: -0.01em; margin-bottom: 8px; }
  .project-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }
  .project-link { display: inline-flex; align-items: center; gap: 6px; margin-top: 16px; font-size: 13px; color: var(--accent); font-weight: 500; }
  .resume-layout { display: grid; grid-template-columns: 1fr 300px; gap: 60px; align-items: start; }
  .resume-left { min-width: 0; }
  .resume-right { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 28px; }
  .sub-section { margin-top: 56px; }
  .timeline { position: relative; }
  .timeline::before { content: ""; position: absolute; left: 0; top: 8px; bottom: 8px; width: 1px; background: var(--border); }
  .timeline-item { position: relative; padding-left: 36px; padding-bottom: 48px; }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-dot { position: absolute; left: -4px; top: 8px; width: 9px; height: 9px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px var(--bg-secondary); }
  .timeline-date { font-size: 12px; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; margin-bottom: 6px; }
  .timeline-role { font-family: var(--font-display); font-size: 20px; font-weight: 600; letter-spacing: -0.01em; margin-bottom: 2px; }
  .timeline-company { font-size: 15px; color: var(--text-secondary); margin-bottom: 10px; }
  .timeline-desc { font-size: 14px; color: var(--text-muted); line-height: 1.7; }
  .timeline-skills { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
  .timeline-skill { font-size: 11px; color: var(--text-secondary); border: 1px solid var(--border); padding: 3px 10px; border-radius: 4px; }
  .sidebar-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 24px; }
  .sidebar-label { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); font-weight: 500; margin-bottom: 16px; }
  .pill-grid { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill { font-size: 13px; color: var(--text-secondary); border: 1px solid var(--border); padding: 6px 14px; border-radius: 20px; transition: border-color 0.3s, color 0.3s; }
  .pill:hover { border-color: rgba(200,168,124,0.4); color: var(--text-primary); }
  .edu-section { margin-top: 72px; }
  .education-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 16px; }
  .edu-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 24px; }
  .edu-degree { font-family: var(--font-display); font-size: 16px; font-weight: 600; margin-bottom: 4px; }
  .edu-school { color: var(--text-secondary); font-size: 14px; margin-bottom: 4px; }
  .edu-year { font-size: 12px; color: var(--accent); font-weight: 500; }

  @media (max-width: 900px) {
    .hero { flex-direction: column; padding: 100px 24px 60px; }
    .hero-cards { width: 100%; }
    .hero-playground-hint { display: none; }
    .resume-layout { grid-template-columns: 1fr; }
    .resume-right { position: static; flex-direction: row; flex-wrap: wrap; }
    .resume-right .sidebar-card { flex: 1; min-width: 200px; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
