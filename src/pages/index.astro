---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { personalInfo, experience, education } from "../content/resume.ts";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);

const gradients = [
  "linear-gradient(135deg, #1a1a2e, #16213e, #0f3460)",
  "linear-gradient(135deg, #1a1410, #2a1e14, #3a2818)",
  "linear-gradient(135deg, #0a1a1a, #0e2626, #123232)",
];
---

<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-label">Portfolio &mdash; {new Date().getFullYear()}</div>
    <h1>
      {personalInfo.tagline.split(" ").slice(0, -1).join(" ")}
      <br /><em>{personalInfo.tagline.split(" ").slice(-1)}</em>
    </h1>
    <p class="hero-description">{personalInfo.description}</p>
    <div class="hero-cta">
      <a href="#projects" class="btn btn-primary">View Projects &darr;</a>
      <a href="#resume" class="btn btn-ghost">Resume</a>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects">
    <div class="section-header">
      <div class="section-label">Selected Work</div>
      <h2 class="section-title">Projects</h2>
    </div>
    <div class="projects-grid">
      {projects.map((project, i) => (
        <a href={project.data.link || project.data.github || "#"} class="project-card" target="_blank" rel="noopener">
          <div class="project-image-wrapper">
            {project.data.image ? (
              <img src={project.data.image} alt={project.data.title} class="project-image" />
            ) : (
              <div class="project-placeholder" style={`background: ${gradients[i % gradients.length]}`}>
                {String(i + 1).padStart(2, "0")}
              </div>
            )}
          </div>
          <div class="project-content">
            <div class="project-tags">
              {project.data.tags.map((tag: string) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>
            <span class="project-link">View project &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- RESUME -->
  <section id="resume" class="resume-section">
    <div class="section-header">
      <div class="section-label">Experience</div>
      <h2 class="section-title">Resume</h2>
    </div>
    <div class="timeline">
      {experience.map((item) => (
        <div class="timeline-item">
          <div class="timeline-dot" />
          <div class="timeline-date">{item.date}</div>
          <div class="timeline-role">{item.role}</div>
          <div class="timeline-company">{item.company}</div>
          <div class="timeline-desc">{item.description}</div>
          <div class="timeline-skills">
            {item.skills.map((s: string) => (
              <span class="timeline-skill">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    {education.length > 0 && (
      <div class="edu-section">
        <div class="section-label">Education</div>
        <div class="education-grid">
          {education.map((ed) => (
            <div class="edu-card">
              <div class="edu-degree">{ed.degree}</div>
              <div class="edu-school">{ed.school}</div>
              <div class="edu-year">{ed.years}</div>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</Base>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 48px 80px;
    max-width: 900px;
  }
  .hero-label {
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    font-weight: 500;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.2s;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 72px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.4s;
  }
  .hero h1 em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }
  .hero-description {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.8;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.6s;
  }
  .hero-cta {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.8s;
  }

  section { padding: 100px 48px; }
  .section-header { margin-bottom: 60px; }
  .resume-section { background: var(--bg-secondary); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }
  .project-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
    transform: translateY(-4px);
  }
  .project-image-wrapper { height: 200px; overflow: hidden; }
  .project-image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .project-card:hover .project-image { transform: scale(1.03); }
  .project-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 48px; font-weight: 200; color: var(--text-muted);
  }
  .project-content { padding: 24px; }
  .project-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
  .project-tag {
    font-size: 11px; font-weight: 500; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--accent);
    background: var(--accent-dim); padding: 4px 10px; border-radius: 4px;
  }
  .project-title {
    font-family: var(--font-display); font-size: 20px;
    font-weight: 600; letter-spacing: -0.01em; margin-bottom: 8px;
  }
  .project-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }
  .project-link {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 16px; font-size: 13px; color: var(--accent); font-weight: 500;
  }

  .timeline { position: relative; max-width: 700px; }
  .timeline::before {
    content: ""; position: absolute; left: 0; top: 8px; bottom: 8px;
    width: 1px; background: var(--border);
  }
  .timeline-item { position: relative; padding-left: 36px; padding-bottom: 48px; }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-dot {
    position: absolute; left: -4px; top: 8px;
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--accent); box-shadow: 0 0 0 4px var(--bg-secondary);
  }
  .timeline-date {
    font-size: 12px; color: var(--accent); letter-spacing: 0.08em;
    text-transform: uppercase; font-weight: 500; margin-bottom: 6px;
  }
  .timeline-role {
    font-family: var(--font-display); font-size: 20px;
    font-weight: 600; letter-spacing: -0.01em; margin-bottom: 2px;
  }
  .timeline-company { font-size: 15px; color: var(--text-secondary); margin-bottom: 10px; }
  .timeline-desc { font-size: 14px; color: var(--text-muted); line-height: 1.7; }
  .timeline-skills { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
  .timeline-skill {
    font-size: 11px; color: var(--text-secondary);
    border: 1px solid var(--border); padding: 3px 10px; border-radius: 4px;
  }

  .edu-section { margin-top: 72px; }
  .education-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px; margin-top: 16px;
  }
  .edu-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 24px;
  }
  .edu-degree { font-family: var(--font-display); font-size: 16px; font-weight: 600; margin-bottom: 4px; }
  .edu-school { color: var(--text-secondary); font-size: 14px; margin-bottom: 4px; }
  .edu-year { font-size: 12px; color: var(--accent); font-weight: 500; }

  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; }
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
